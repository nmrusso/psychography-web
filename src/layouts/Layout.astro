---
import Nav from '../components/Nav.astro';
import TweaksPanel from '../components/TweaksPanel.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Psychography — Modern Metal / Thall',
  description = 'Psychography — Modern Metal from Buenos Aires, Argentina. Est. 2020. Distributed by Arson Theory.',
} = Astro.props;
