const LANG_KEY = 'psy_lang';
function getLang() {
  try { return localStorage.getItem(LANG_KEY) || 'en'; } catch(e) { return 'en'; }
}
function setLang(lang) {
  if (lang !== 'en' && lang !== 'es') lang = 'en';
  const dict = I18N[lang];
  document.documentElement.lang = lang;

  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (dict[key] != null) el.textContent = decodeEntities(dict[key]);
  });
  document.querySelectorAll('[data-i18n-html]').forEach(el => {
    const key = el.getAttribute('data-i18n-html');
    if (dict[key] != null) el.innerHTML = dict[key];
  });
  document.querySelectorAll('[data-i18n-aria-label]').forEach(el => {
    const key = el.getAttribute('data-i18n-aria-label');
    if (dict[key] != null) el.setAttribute('aria-label', decodeEntities(dict[key]));
  });

  const btn = document.getElementById('langToggle');
  if (btn) {
    btn.setAttribute('data-lang', lang);
    btn.setAttribute('aria-label', lang === 'en' ? 'Switch to Spanish' : 'Cambiar a inglés');
    btn.setAttribute('title', lang === 'en' ? 'Switch to Spanish' : 'Cambiar a inglés');
  }

  try { localStorage.setItem(LANG_KEY, lang); } catch(e) {}
}
function decodeEntities(html) {
  const t = document.createElement('textarea');
  t.innerHTML = html;
  return t.value;
}

setLang(getLang());

document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('langToggle');
  if (!btn) return;
  btn.addEventListener('click', () => {
    const next = getLang() === 'en' ? 'es' : 'en';
    setLang(next);
  });
});
</script>

<!-- MAIN SCRIPTS: tweaks, nav scroll, reveal, cursor -->
<script is:inline>
const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
  "theme": "violet",
  "hero-bg": "poster",
  "title-style": "outline",
  "cursor": "on"
}/*EDITMODE-END*/;

/* ---------- NAV scroll ---------- */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 50);
});

/* ---------- Reveal on scroll ---------- */
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('is-visible');
      io.unobserve(e.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

/* ---------- Cursor ---------- */
const dot = document.getElementById('cursorDot');
const ring = document.getElementById('cursorRing');
let rx = 0, ry = 0, dx = 0, dy = 0;
window.addEventListener('mousemove', (e) => {
  dx = e.clientX; dy = e.clientY;
  dot.style.transform = `translate(${dx}px, ${dy}px) translate(-50%,-50%)`;
});
function rafRing() {
  rx += (dx - rx) * 0.18;
  ry += (dy - ry) * 0.18;
  ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%,-50%)`;
  requestAnimationFrame(rafRing);
}
rafRing();
document.querySelectorAll('a, button, .press-card, .member, .show, .music__cover').forEach(el => {
  el.addEventListener('mouseenter', () => ring.classList.add('hover'));
  el.addEventListener('mouseleave', () => ring.classList.remove('hover'));
});

/* ---------- Tweaks ---------- */
const state = { ...TWEAK_DEFAULTS };

function applyTweaks() {
  document.body.classList.remove('theme-violet', 'theme-red');
  if (state.theme === 'violet') document.body.classList.add('theme-violet');
  if (state.theme === 'red') document.body.classList.add('theme-red');

  const bg = document.querySelector('.hero__bg');
  const map = { band: 'assets/band-hero.webp', poster: 'assets/poster-movie.webp', still: 'assets/screams-still.webp' };
  bg.style.backgroundImage = `url('${map[state['hero-bg']]}')`;

  const t = document.querySelector('.hero__title');
  if (t && !t.classList.contains('hero__title--logo')) {
    if (state['title-style'] === 'italic') {
      t.innerHTML = '<em>Psycho<span style="font-style:italic">graphy</span></em>';
      t.style.fontStyle = 'italic';
    } else if (state['title-style'] === 'outline') {
      t.innerHTML = '<span class="outlined">Psycho</span><em>graphy</em>';
      t.style.fontStyle = 'normal';
    } else {
      t.innerHTML = '<span class="thin">Psycho</span><em>graphy</em>';
      t.style.fontStyle = 'normal';
    }
  }

  const d = document.getElementById('cursorDot');
  const r = document.getElementById('cursorRing');
  if (state.cursor === 'off') { d.style.display = 'none'; r.style.display = 'none'; }
  else if (state.cursor === 'dot') { d.style.display = 'block'; r.style.display = 'none'; }
  else { d.style.display = 'block'; r.style.display = 'block'; }

  if (window.PsyFX) window.PsyFX.setLevel('full');

  document.querySelectorAll('.tweaks__opts').forEach(group => {
    const key = group.dataset.group;
    group.querySelectorAll('.tweaks__opt').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.val === state[key]);
    });
  });
}
applyTweaks();

document.querySelectorAll('.tweaks__opts').forEach(group => {
  const key = group.dataset.group;
  group.querySelectorAll('.tweaks__opt').forEach(btn => {
    btn.addEventListener('click', () => {
      state[key] = btn.dataset.val;
      applyTweaks();
      try {
        window.parent.postMessage({ type: '__edit_mode_set_keys', edits: { [key]: btn.dataset.val } }, '*');
      } catch (e) {}
    });
  });
});

/* ---------- Tweaks host hooks ---------- */
window.addEventListener('message', (e) => {
  const d = e.data || {};
  if (d.type === '__activate_edit_mode') document.getElementById('tweaks').classList.add('open');
  if (d.type === '__deactivate_edit_mode') document.getElementById('tweaks').classList.remove('open');
});
try { window.parent.postMessage({ type: '__edit_mode_available' }, '*'); } catch(e) {}
</script>

<script src="/fx.js" defer></script>

</body>
